# Smart Parking Web App - Environment Variables Template
# Copy this file to '.env' and fill in your actual production configurations.

# Backend server Port
PORT=5000

# Server Node environment (development or production)
NODE_ENV=production

# MongoDB Atlas cluster connection string URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/Bookparking

# Cryptographically strong JWT Token Secret (do not share!)
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_production_secure_jwt_secret_key_here

# Frontend Application URL (for CORS validation and reset links)
FRONTEND_URL=https://your-smart-parking-app.vercel.app

# Real Email Service Transporter configuration (e.g., SMTP settings)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
